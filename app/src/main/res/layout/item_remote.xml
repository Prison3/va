<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    tools:ignore="HardcodedText">

    <CheckBox
        android:id="@+id/item_remote_check"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:clickable="false" />

    <ImageView
        android:id="@+id/item_remote_img"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:padding="5dp" />

    <LinearLayout
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="5dp">

        <TextView
            android:id="@+id/item_remote_app_info"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center_vertical"
            android:text="app_info:"
            android:textColor="@color/defaultText"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/item_remote_ver_info"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center_vertical"
            android:text="ver_info:"
            android:textColor="@color/defaultText"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/item_remote_open"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:text="open"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/item_remote_stop"
        android:layout_width="60dp"
        android:layout_height="40dp"
        android:text="stop"
        android:textAllCaps="false" />
</LinearLayout>