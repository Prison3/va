    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="40dp">

        <CheckBox
            android:id="@+id/main_check_wifi"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:clickable="false"
            android:text="WifiConnect"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/main_text_wifi"
            android:layout_width="180dp"
            android:layout_height="match_parent"
            android:layout_marginStart="110dp"
            android:gravity="center"
            android:text="no connect"
            android:textColor="@color/defaultText"
            android:textSize="12sp" />

        <Button
            android:id="@+id/main_btn_wifi"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:layout_marginEnd="10dp"
            android:text="settings"
            android:textAllCaps="false"
            android:textSize="12sp" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="40dp">

        <CheckBox
            android:id="@+id/main_check_grpc"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:clickable="false"
            android:text="GrpcConnect"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/main_edit_grpc"
            android:layout_width="180dp"
            android:layout_height="match_parent"
            android:layout_marginStart="110dp"
            android:layout_marginBottom="-2dp"
            android:focusedByDefault="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/main_btn_grpc"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:layout_marginEnd="10dp"
            android:text="change"
            android:textAllCaps="false"
            android:textSize="12sp" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:background="#4D000000"
        android:layout_height="1dp"/>

    <LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!--https://github.com/ogaclejapan/SmartTabLayout -->
        <com.ogaclejapan.smarttablayout.SmartTabLayout
            android:id="@+id/main_tab"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@color/mainBar"
            app:stl_clickable="true"
            app:stl_defaultTabTextAllCaps="false"
            app:stl_defaultTabTextColor="#FC000000"
            app:stl_defaultTabTextHorizontalPadding="12dp"
            app:stl_defaultTabTextMinWidth="0dp"
            app:stl_defaultTabTextSize="14sp"
            app:stl_distributeEvenly="true"
            app:stl_dividerColor="#4D000000"
            app:stl_dividerThickness="2dp"
            app:stl_drawDecorationAfterTab="false"
            app:stl_indicatorAlwaysInCenter="false"
            app:stl_indicatorColor="#40C4FF"
            app:stl_indicatorCornerRadius="2dp"
            app:stl_indicatorGravity="bottom"
            app:stl_indicatorInFront="false"
            app:stl_indicatorInterpolation="smart"
            app:stl_indicatorThickness="4dp"
            app:stl_indicatorWidth="auto"
            app:stl_indicatorWithoutPadding="false"
            app:stl_overlineColor="#4D000000"
            app:stl_overlineThickness="0dp"
            app:stl_titleOffset="24dp"
            app:stl_underlineColor="#4D000000"
            app:stl_underlineThickness="1dp" />

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/main_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>
</LinearLayout>