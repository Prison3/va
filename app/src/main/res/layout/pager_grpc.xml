<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/grpc_recycler_view"
        android:layout_width="240dp"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="HardcodedText">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:background="@color/pagerBar"
                android:gravity="center"
                android:text="Today traffic used"
                android:textColor="@color/defaultText"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/grpc_text_traffic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:text="\nlongclick to load\n"
                android:textColor="@color/defaultText"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:background="@color/pagerBar"
                android:gravity="center"
                android:text="Today xposed counter"
                android:textColor="@color/defaultText"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/grpc_text_xposed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:textColor="@color/defaultText"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>