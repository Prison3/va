{
  "log": {
    "access": "%1$s",
    "error": "%2$s",
    "loglevel": "info"
  },
  "stats": {},
  "api": {
    "tag": "api",
    "services": [
      "StatsService"
    ]
  },
  "policy": {
    "system": {
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "inbounds": [{
    "port": %3$s,
    "listen": "0.0.0.0",
    "tag": "socks-inbound",
    "protocol": "socks",
    "settings": {
      "auth": "noauth",
      "udp": false
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    }
  },{
    "port": %4$s,
    "protocol": "dokodemo-door",
    "settings": {
      "network": "tcp",
      "followRedirect": true
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"]
    },
    "tag": "transparent-inbound"
  },{
    "listen": "127.0.0.1",
    "port": %5$s,
    "protocol": "dokodemo-door",
    "settings": {
      "address": "127.0.0.1"
    },
    "tag": "api"
  }],
  "outbounds": [{
    "protocol": "%6$s",
    "settings": {
      "servers": [{
        "address": "%7$s",
        "port": %8$s,
        "users": [
          %9$s
      ]
      }]
    },
    %10$s
    "tag": "socks-outbound"
  }%11$s,{
    "protocol": "freedom",
    "settings": {},
    "tag": "direct"
  }],
  "routing": %12$s
}
